{
  "name": "frogconvert",
  "productName": "frogConvert",
  "author": "ogfrench",
  "description": "Truly universal browser-based file converter",
  "private": true,
  "version": "0.1.0",
  "homepage": "https://frogconvert.xyz",
  "repository": "https://github.com/ogfrench/frogConvert",
  "type": "module",
  "main": "src/electron.cjs",
  "scripts": {
    "dev": "bun x vite",
    "mcp": "bun src/mcp/index.ts",
    "build": "bun x tsc && bun x vite build",
    "test": "bun x vitest run",
    "test:watch": "bun x vitest",
    "cache:build": "bun run scripts/buildCache.js dist/cache.json --minify",
    "cache:build:dev": "bun run scripts/buildCache.js dist/cache.json",
    "preview": "bun x vite preview",
    "docker": "bun run docker:build && bun run docker:up",
    "docker:build": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.override.yml build --build-arg VITE_COMMIT_SHA=$(git rev-parse HEAD)",
    "docker:up": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.override.yml up -d",
    "desktop:build": "bun x tsc && IS_DESKTOP=true bun x vite build && bun run cache:build",
    "desktop:preview": "bun x electron .",
    "desktop:start": "bun run desktop:build && bun run desktop:preview",
    "desktop:dist:win": "bun run desktop:build && bun x electron-builder --win --publish never",
    "desktop:dist:mac": "bun run desktop:build && bun x electron-builder --mac --publish never",
    "desktop:dist:linux": "bun run desktop:build && bun x electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.ogfrench.frogconvert",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/electron.cjs"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/jszip": "^3.4.0",
    "@types/opentype.js": "^1.3.9",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "puppeteer": "^24.36.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@flo-audio/reflo": "^0.1.2",
    "@imagemagick/magick-wasm": "^0.0.37",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "yaml": "^2.8.2",
    "@stringsync/vexml": "^0.1.8",
    "@toon-format/toon": "^2.1.0",
    "@types/bun": "^1.3.9",
    "@types/meyda": "^5.3.0",
    "@types/pako": "^2.0.4",
    "@types/three": "^0.182.0",
    "bson": "^7.2.0",
    "file-saver": "^2.0.5",
    "imagetracer": "^0.2.2",
    "js-synthesizer": "^1.11.0",
    "jszip": "^3.10.1",
    "meyda": "^5.6.3",
    "mime": "^4.1.0",
    "nbtify": "^2.2.0",
    "opentype.js": "^1.3.4",
    "pako": "^2.1.0",
    "pdftoimg-js": "^0.2.5",
    "pe-library": "^2.0.1",
    "svg-pathdata": "^8.0.0",
    "three": "^0.182.0",
    "three-bvh-csg": "^0.0.17",
    "three-mesh-bvh": "^0.9.8",
    "ts-flp": "^1.0.3",
    "verovio": "^6.0.1",
    "vexflow": "^5.0.0",
    "vite-plugin-static-copy": "^3.1.6",
    "wavefile": "^11.0.0",
    "woff2-encoder": "^2.0.0"
  }
}